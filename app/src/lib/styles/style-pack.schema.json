{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinitymix.local/schemas/style-pack.schema.json",
  "title": "InfinityMix Style Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "planner"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-_]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "isBuiltIn": {
      "type": "boolean"
    },
    "planner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["energyArc", "transitions", "constraints"],
      "properties": {
        "energyArc": {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile"],
          "properties": {
            "profile": {
              "type": "string",
              "enum": ["steady", "build", "wave"]
            },
            "targetCurve": {
              "type": "string",
              "enum": ["flat", "rising", "rolling"]
            },
            "peakWindow": {
              "type": "array",
              "items": { "type": "number", "minimum": 0, "maximum": 1 },
              "minItems": 2,
              "maxItems": 2
            }
          }
        },
        "phraseLengthsBars": {
          "type": "array",
          "items": { "type": "integer", "minimum": 2, "maximum": 64 },
          "minItems": 1,
          "maxItems": 8
        },
        "sectionPriorities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["intro", "verse", "chorus", "hook", "bridge", "buildup", "drop", "outro"]
          },
          "maxItems": 12
        },
        "sectionQuotas": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minVocalSegments": { "type": "integer", "minimum": 0, "maximum": 64 },
            "minInstrumentalSegments": { "type": "integer", "minimum": 0, "maximum": 64 },
            "maxHighEnergySegmentsInRow": { "type": "integer", "minimum": 1, "maximum": 16 }
          }
        },
        "transitions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["preferred"],
          "properties": {
            "preferred": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "smooth",
                  "drop",
                  "cut",
                  "energy",
                  "filter_sweep",
                  "echo_reverb",
                  "backspin",
                  "tape_stop",
                  "stutter_edit",
                  "three_band_swap",
                  "bass_drop",
                  "snare_roll",
                  "noise_riser",
                  "vocal_handoff",
                  "bass_swap",
                  "reverb_wash",
                  "echo_out"
                ]
              },
              "minItems": 1,
              "maxItems": 12
            },
            "disallowed": {
              "type": "array",
              "items": { "$ref": "#/properties/planner/properties/transitions/properties/preferred/items" },
              "maxItems": 12
            },
            "defaultStyle": {
              "$ref": "#/properties/planner/properties/transitions/properties/preferred/items"
            },
            "durationMultiplier": {
              "type": "number",
              "minimum": 0.25,
              "maximum": 3
            },
            "fxUsage": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxWetFx": { "type": "number", "minimum": 0, "maximum": 1 },
                "allowPreviewOnlyFx": { "type": "boolean" }
              }
            }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["phraseSafety", "genreCompatibility"],
          "properties": {
            "phraseSafety": {
              "type": "string",
              "enum": ["strict", "balanced", "loose"]
            },
            "genreCompatibility": {
              "type": "string",
              "enum": ["strict", "balanced", "loose"]
            },
            "requireKeyCompatibility": { "type": "boolean" },
            "preferStems": { "type": "boolean" },
            "keepOrder": { "type": "boolean" }
          }
        },
        "debug": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "traceEnabledDefault": { "type": "boolean" },
            "emitRejectedAlternatives": { "type": "boolean" }
          }
        }
      }
    }
  }
}
